AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_DEV_MODE="true"
APP_BASE_URL="http://localhost:3000"

# Optional production email delivery for one-time login codes.
RESEND_API_KEY=""
LOGIN_EMAIL_FROM="Arcana AI <login@example.com>"

# Google OAuth sign-in.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI tarot interpretation. Set ONE provider key. Without any key, readings fall
# back to deterministic Rider-Waite text so the app still runs. The provider is
# auto-detected (Gemini preferred) unless AI_PROVIDER forces one.
# Google Gemini (AI Studio / Generative Language API key):
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
# Anthropic Claude:
ANTHROPIC_API_KEY=""
AI_MODEL="claude-opus-4-8"
# AI_PROVIDER="gemini"   # optional: force "gemini" or "anthropic"

# Stripe subscriptions. Use test keys (sk_test_… / pk_test_…) first; switch to
# live keys only after testing. Test vs live mode is implied by the key prefix.
# STRIPE_WEBHOOK_SECRET is the signing secret (whsec_…) for your webhook endpoint.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Optional — hosted Checkout does not use the publishable key client-side.
STRIPE_PUBLISHABLE_KEY=""
# Current plans: Quarterly Pass ($19.99 / 90 days) and Monthly Pass ($9.99 / 30 days).
STRIPE_PRICE_ID_QUARTERLY=""
STRIPE_PRICE_ID_MONTHLY=""
